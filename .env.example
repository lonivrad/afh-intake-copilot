# Anthropic API key (required)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Note: the Claude model is not configurable via this file. It is a fixed
# constant (claude-sonnet-4-6) set as MODEL_ID in each pipeline module.

# Optional: Streamlit server settings (useful for local dev)
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_HEADLESS=true
